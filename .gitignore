obj_dir/
**/obj_dir/

# Icarus Verilog
*.vvp

# Waveforms
*.vcd
*.fst
*.ghw
*.wlf

# Generic logs / coverage
*.log
*.jou
coverage/

# --- Editor / OS junk ---
.DS_Store
*.swp
*~

# --- Python (cocotb, helper scripts) ---
__pycache__/
*.pyc
.venv/

# Note: pd/ has its own .gitignore for OpenLane runs/.
